# --- Supabase ---------------------------------------------------------
# From Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Anthropic --------------------------------------------------------
# console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Models used by the agent. Defaults are sensible; override if you want
# to test cheaper/faster runs locally.
ANTHROPIC_MODEL_EXTRACT=claude-opus-4-7
ANTHROPIC_MODEL_COPY=claude-haiku-4-5-20251001

# --- Email (Resend) ---------------------------------------------------
# resend.com -> API Keys. Free tier is fine.
# If unset, the app falls back to a console log so the demo still runs.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Marcus Tate <marcus@example.com>

# --- Stripe (test mode) ----------------------------------------------
# dashboard.stripe.com/test/apikeys -> Secret key (sk_test_...)
# If unset, deposit links fall back to a mocked URL.
STRIPE_SECRET_KEY=sk_test_...

# --- GoHighLevel (real or mocked) ------------------------------------
# Leave both blank to use the MockGHLAdapter (logs to audit_log only).
# When real, the agent will push proposal events to a GHL sub-account.
GHL_API_KEY=
GHL_LOCATION_ID=

# --- Slack (optional) -------------------------------------------------
# Incoming webhook for Marcus to get a Slack ping when a proposal needs
# approval. Leave blank to disable.
SLACK_APPROVAL_WEBHOOK_URL=

# --- App ---------------------------------------------------------------
# Public URL of the deployment. Used in approval emails and links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of approver emails. The /approve route checks
# the JWT/cookie against this list before allowing approval.
# For this MVP, any "approver" header value in this list is accepted.
APPROVER_EMAILS=marcus@greenscapepro.test
